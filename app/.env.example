# Firebase client SDK (public — safe to expose in browser)
# Find these in Firebase Console → Project Settings → Your apps → Web app
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ─── Firebase Admin (for deployment — not needed for local dev) ──────────────
# Paste the entire contents of service-account.json as a single-line JSON string
# Only needed when deploying (Vercel, etc.) — locally, just place the file in project root
# FIREBASE_SERVICE_ACCOUNT_JSON=

# ─── AI Providers (set one or both) ──────────────────────────────────────────
# Get your key from https://console.anthropic.com
ANTHROPIC_API_KEY=

# Get your key from https://platform.openai.com/api-keys
OPENAI_API_KEY=

# ─── JWT Auth ─────────────────────────────────────────────────────────────────
# Any long random string — generate with: openssl rand -base64 32
JWT_SECRET=

# ─── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
